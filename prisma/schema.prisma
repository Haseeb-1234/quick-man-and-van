generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id                 String        @id @default(cuid())
  customerId         String?
  collectionAddress  String
  collectionPostcode String
  deliveryAddress    String
  deliveryPostcode   String
  stops              Json?
  collectionStairs   Int           @default(0)
  deliveryStairs     Int           @default(0)
  moveDate           DateTime
  vanSize            String
  helpers            Int           @default(0)
  price              Float
  bookedHours        Float?
  bookedVanType      Int?
  stripePaymentId    String?
  stripeSessionId    String?
  checkoutToken      String?
  status             BookingStatus @default(PENDING)
  contactEmail       String?
  contactName        String?
  contactPhone       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  customer           Customer?     @relation(fields: [customerId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model PricingSettings {
  id            String   @id @default("singleton")
  companyName   String   @default("Man and Van")
  rating        Float    @default(4.9)
  reviewCount   Int      @default(0)
  smallVanRate  Float    @default(25)
  mediumVanRate Float    @default(35)
  largeVanRate  Float    @default(45)
  lutonVanRate  Float    @default(55)
  helper2Rate   Float    @default(12)
  helper3Rate   Float    @default(24)
  stairRate     Float    @default(5)
  stopRate      Float    @default(10)
  minHours      Float    @default(5)
  maxHours      Float    @default(17.5)
  updatedAt     DateTime @updatedAt
}
